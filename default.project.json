{
  "name": "CoinCollector",
  "servePort": 34872,
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "$ignoreUnknownInstances": true,
      "CoinConstants": { "$path": "src/shared/CoinConstants.lua" },
      "CoinUtility": { "$path": "src/shared/CoinUtility.lua" },
      "PlayerData": { "$path": "src/shared/PlayerData.lua" }
    },
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "Server": { "$path": "src/server" }
    },
    "ServerStorage": {
      "$className": "ServerStorage",
      "CoinTemplate": { "$path": "src/workspace/Coin.rbxm" }
    },
    "StarterGui": {
      "$className": "StarterGui",
      "CoinDisplayGui": { "$path": "src/gui/CoinDisplayGui.rbxm" }
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "Client": { "$path": "src/client" }
      }
    }
  }
}